{
  "name": "agent-office",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"tsx watch src/server/index.ts\" \"tsx esbuild.config.ts --watch\"",
    "build": "tsx esbuild.config.ts && tsc -p tsconfig.server.json",
    "start": "node dist/server/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check . --max-diagnostics 1000",
    "lint:fix": "biome lint --unsafe . --max-diagnostics 1000",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.69",
    "better-sqlite3": "^12.6.2",
    "express": "^5.1.0",
    "pixi.js": "^8.9.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.2",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.1",
    "happy-dom": "^20.8.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
